# OpenDraft web — build-time config (Vite import.meta.env).
#
# Leave everything unset for local dev: `pnpm dev` uses the Vite proxy to the
# local no-AWS harness (see vite.config.ts). Set these for a DEPLOYED build so
# the app talks to the API Gateway + CloudFront origins directly.
#
# Values map 1:1 to the Terraform outputs (see infra/outputs.tf).

# HTTP API base URL — `terraform output -raw http_api_endpoint`.
# Dev fallback: /api
# VITE_HTTP_BASE=https://abc123.execute-api.us-east-1.amazonaws.com

# WebSocket URL (wss://) — `terraform output -raw ws_client_url`.
# Dev fallback: ws(s)://<host>/ws derived from location.
# VITE_WS_URL=wss://xyz789.execute-api.us-east-1.amazonaws.com/prod

# League id — must match the backend.
# Dev fallback: dev-league
# VITE_LEAGUE_ID=my-league

# Pool base URL — CloudFront domain + /pools (note the plural prefix).
# Domain: `terraform output -raw cloudfront_domain_name`.
# Dev fallback: /pool
# VITE_POOL_BASE=https://d111111abcdef8.cloudfront.net/pools
