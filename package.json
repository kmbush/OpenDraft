{
  "name": "opendraft",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n harness,web \"pnpm --filter @opendraft/dev-server start\" \"pnpm --filter @opendraft/web dev\"",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "concurrently": "9.1.0",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
